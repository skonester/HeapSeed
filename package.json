{
  "name": "HeapSeed",
  "productName": "HeapSeed",
  "version": "1.0.0",
  "description": "HeapSeed",
  "main": "src/app.js",
  "scripts": {
    "start": "electron .",
    "clean": "rmdir /s /q dist 2>nul",
    "dist": "npm run clean && electron-builder --win nsis --linux deb rpm --x64",
    "pack-all": "npm run pack-windows && npm run pack-linux && open dist/",
    "pack-mac": "npx electron-builder -m --x64 --arm64",
    "pack-linux": "npx electron-builder --linux deb rpm tar.xz --x64",
    "pack-windows": "npx electron-builder --win nsis --x64"
  },
  "keywords": [
    "magnet",
    "torrent",
    "webtorrent"
  ],
  "author": "Skonester",
  "license": "ISC",
  "build": {
    "appId": "com.skonester.heapseed",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.{o,obj,pdb,h,cpp,c,cc}"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Skonester",
        "repo": "HeapSeed"
      }
    ],
    "mac": {
      "notarize": false,
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "deb",
        "rpm"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "protocols": [
      {
        "name": "Magnet URL",
        "schemes": [
          "magnet"
        ]
      }
    ]
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "plyr": "^3.8.4",
    "sound-play": "^1.1.0",
    "trash": "^10.1.1",
    "webtorrent": "^2.8.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "node-gyp": "^12.2.0"
  }
}
