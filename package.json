{
  "name": "HeapSeed",
  "productName": "HeapSeed",
  "version": "1.0.1",
  "main": "src/app.js",
  "scripts": {
    "start": "electron .",
    "clean": "rimraf dist",
    "build": "npm run clean && electron-builder --win nsis portable --x64"
  },
  "build": {
    "appId": "com.skonester.heapseed",
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Network",
      "icon": "build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Skonester",
        "repo": "HeapSeed"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.7.7",
    "electron-updater": "^6.7.0",
    "plyr": "^3.7.8",
    "sound-play": "^1.1.0",
    "trash": "^8.1.1",
    "webtorrent": "^2.1.21"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.5",
    "rimraf": "^6.1.3"
  }
}