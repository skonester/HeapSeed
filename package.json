{
  "name": "HeapSeed",
  "productName": "HeapSeed",
  "version": "1.0.9",
  "description": "HeapSeed Network Application",
  "author": {
    "name": "skonester",
    "email": "admin@skonester.com"
  },
  "main": "boot.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skonester/heapseed.git"
  },
  "scripts": {
    "start": "electron .",
    "clean": "rimraf dist",
    "build:linux": "npm run clean && electron-builder --linux AppImage --x64",
    "build": "npm run clean && electron-builder --win nsis portable --x64"
  },
  "build": {
    "appId": "com.skonester.heapseed",
    "afterPack": "./scripts/fix-codecs.js",
    "asar": true,
    "asarUnpack": [
      "build-assets/**"
    ],
    "extraResources": [
      {
        "from": "build-assets/libffmpeg.so",
        "to": "lib/libffmpeg.so"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "skonester",
        "repo": "heapseed"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Network",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.7.0",
    "plyr": "^3.7.8",
    "sound-play": "^1.1.0",
    "trash": "^8.1.1",
    "webtorrent": "^2.1.21"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.1.3"
  }
}
